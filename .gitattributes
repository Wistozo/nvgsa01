# Normalise les fins de ligne pour tous les fichiers texte
* text=auto eol=lf

# Forcer LF pour ces types
*.tsx text eol=lf
*.ts  text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.html text eol=lf
*.md  text eol=lf
*.xml text eol=lf

# Fichiers binaires — pas de conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
